datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id        String        @id @default(uuid())
  slug      String        @unique
  name      String
  createdAt DateTime      @default(now())
  users     User[]
  tasks     Task[]
  logs      ActivityLog[]
}

model User {
  id             String        @id @default(uuid())
  tenantId       String
  email          String        @unique
  passwordHash   String
  role           String        // Admin | Member
  name           String
  createdAt      DateTime      @default(now())
  
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedTasks  Task[]
  logs           ActivityLog[]
}

model Task {
  id          String   @id @default(uuid())
  tenantId    String
  title       String
  description String
  status      String   // Todo | InProgress | Done
  priority    String   // Low | Medium | High
  dueDate     DateTime
  assigneeId  String?
  attachments String   // JSON stringified array of URLs
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignee    User?    @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
}

model ActivityLog {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  action    String
  details   String
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
